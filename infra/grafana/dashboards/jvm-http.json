{
  "title": "JVM + HTTP",
  "uid": "jvm-http",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["jvm", "http", "micrometer"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap usage by area",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{application=~\"$service\", area=\"heap\"})",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GC pause (sum, 1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum{application=~\"$service\"}[1m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "jvm_threads_live_threads{application=~\"$service\"}", "legendFormat": "live" },
        { "expr": "jvm_threads_daemon_threads{application=~\"$service\"}", "legendFormat": "daemon" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "process_cpu_usage{application=~\"$service\"}", "legendFormat": "process" },
        { "expr": "system_cpu_usage{application=~\"$service\"}", "legendFormat": "system" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate by URI",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{application=~\"$service\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP p95 latency by URI",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx {{uri}}"
        }
      ]
    }
  ]
}
