{
  "title": "Slow Query & N+1",
  "uid": "slow-query",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["jdbc", "n+1", "slow-query", "modules"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(query_execution_seconds_count, application)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "N+1 detected (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "targets": [
        { "expr": "sum(increase(n_plus_one_total{application=~\"$service\"}[5m]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Slow queries (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 50 }
          ]}
        }
      },
      "targets": [
        { "expr": "sum(increase(slow_query_total{application=~\"$service\"}[5m]))" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Query rate by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "qps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (outcome, application) (rate(query_execution_seconds_count{application=~\"$service\"}[1m]))",
          "legendFormat": "{{application}} · {{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Query latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, application) (rate(query_execution_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "{{application}} p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "N+1 events over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (application) (rate(n_plus_one_total{application=~\"$service\"}[5m]))",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
