# 모든 텍스트 파일은 LF 로 저장 — Windows 클론에서도 동일한 줄 끝 보장.
* text=auto eol=lf

# 명시적 텍스트 (확장자별 — 자동 감지 실패 시 안전망)
*.java       text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.sql        text eol=lf
*.conf       text eol=lf
*.toml       text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf

# Gradle wrapper / 셸 스크립트는 항상 LF + 실행 권한
gradlew      text eol=lf
*.sh         text eol=lf

# Windows 전용 — CRLF 강제
*.bat        text eol=crlf
*.cmd        text eol=crlf

# 바이너리 — diff/머지 시도 안 함
*.jar        binary
*.war        binary
*.ear        binary
*.zip        binary
*.gz         binary
*.tgz        binary
*.tar        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.so         binary
*.dylib      binary
*.dll        binary
*.class      binary
*.jks        binary
*.p12        binary

# linguist — GitHub language stat 에서 제외 (자동 생성/벤더링된 파일)
gradle/wrapper/gradle-wrapper.jar       binary linguist-vendored
gradle/wrapper/gradle-wrapper.properties linguist-vendored
helm/**                                 linguist-generated=false
infra/grafana/dashboards/*.json         linguist-generated
